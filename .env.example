# Template variabili d'ambiente — copia in .env.local e compila.
# Vedi .env.local per la descrizione di ogni variabile.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
INTERVALS_OAUTH_CLIENT_ID=
INTERVALS_OAUTH_CLIENT_SECRET=
TOKEN_ENCRYPTION_KEY=
# Provider AI per i commenti della scheda atleta. Default: groq.
# IMPORTANTE: impostare la stessa coppia (provider + chiave) anche su Vercel,
# altrimenti il commento funziona in locale ma dà errore in produzione.
COACH_AI_PROVIDER=groq
# Chiave del provider selezionato (opzionale): senza, l'app funziona identica,
# solo senza commento AI. Serve GROQ_API_KEY se provider=groq, ANTHROPIC_API_KEY
# se provider=anthropic.
GROQ_API_KEY=
ANTHROPIC_API_KEY=
